{:paths ["vendor/acceptance-pipeline-specification/bb/src"
         "acceptance/src"
         "test"]
 :tasks
 {gherkin-parser aps.cli.gherkin-parser/-main
  gherkin-ir-dry-checker aps.cli.gherkin-ir-dry-checker/-main
  gherkin-mutator aps.cli.gherkin-mutator/-main
  acceptance-entrypoint-generator acceptance.generator/-main
  test:unit {:doc "Run focused unit tests."
             :requires ([clojure.test :as test]
                        [babashka.process :as process]
                        [acceptance.runtime-test]
                        [acceptance.generator-test]
                        [acceptance.steps-support-test]
                        [acceptance.side-panel-steps-test]
                        [acceptance.command-registry-steps-test]
                        [acceptance.palette-steps-test]
                        [acceptance.hotkey-keymap-steps-test]
                        [acceptance.package-flow-steps-test]
                        [acceptance.data-layer-steps-test]
                        [acceptance.data-layer-session-steps-test]
                        [acceptance.data-layer-observer-steps-test]
                        [acceptance.data-layer-timeline-steps-test]
                        [acceptance.data-layer-recovery-steps-test]
                        [acceptance.data-layer-page-context-steps-test]
                        [acceptance.workspace-editor-steps-test]
                        [acceptance.observability-library-steps-test]
                        [acceptance.operator-interface-steps-test]
                        [acceptance.live-observer-steps-test]
                        [acceptance.live-event-presentation-steps-test]
                        [acceptance.event-library-editor-steps-test]
                        [acceptance.schema-verification-steps-test]
                        [acceptance.saved-sessions-steps-test]
                        [acceptance.gherkin-mutation-metadata-test])
             :task (let [result (test/run-tests 'acceptance.runtime-test
                                                'acceptance.generator-test
                                                'acceptance.steps-support-test
                                                'acceptance.side-panel-steps-test
                                                'acceptance.command-registry-steps-test
                                                'acceptance.palette-steps-test
                                                'acceptance.hotkey-keymap-steps-test
                                                'acceptance.package-flow-steps-test
                                                'acceptance.data-layer-steps-test
                                                'acceptance.data-layer-session-steps-test
                                                'acceptance.data-layer-observer-steps-test
                                                'acceptance.data-layer-timeline-steps-test
                                                'acceptance.data-layer-recovery-steps-test
                                                'acceptance.data-layer-page-context-steps-test
                                                'acceptance.workspace-editor-steps-test
                                                'acceptance.observability-library-steps-test
                                                'acceptance.operator-interface-steps-test
                                                'acceptance.live-observer-steps-test
                                                'acceptance.live-event-presentation-steps-test
                                                'acceptance.event-library-editor-steps-test
                                                'acceptance.schema-verification-steps-test
                                                'acceptance.saved-sessions-steps-test
                                                'acceptance.gherkin-mutation-metadata-test)
                         source-result (process/shell {:out :inherit
                                                      :err :inherit
                                                      :continue true}
                                                      "npm" "run" "test:unit:source-foundation")
                         live-result (process/shell {:out :inherit
                                                     :err :inherit
                                                     :continue true}
                                                    "npm" "run" "test:unit:live-observer")
                         presentation-result (process/shell {:out :inherit
                                                             :err :inherit
                                                             :continue true}
                                                            "npm" "run" "test:unit:live-event-presentation")
                         editor-result (process/shell {:out :inherit
                                                       :err :inherit
                                                       :continue true}
                                                      "npm" "run" "test:unit:event-library-editor")
                         schema-result (process/shell {:out :inherit
                                                       :err :inherit
                                                       :continue true}
                                                      "npm" "run" "test:unit:schema-verification")
                         sequence-result (process/shell {:out :inherit
                                                         :err :inherit
                                                         :continue true}
                                                        "npm" "run" "test:unit:sequence-replay")
                         saved-result (process/shell {:out :inherit
                                                      :err :inherit
                                                      :continue true}
                                                     "npm" "run" "test:unit:saved-sessions")]
                     (when (or (pos? (+ (:fail result) (:error result)))
                               (not (zero? (:exit source-result)))
                               (not (zero? (:exit live-result)))
                               (not (zero? (:exit presentation-result)))
                               (not (zero? (:exit editor-result)))
                               (not (zero? (:exit schema-result)))
                               (not (zero? (:exit sequence-result)))
                               (not (zero? (:exit saved-result))))
                       (System/exit 1)))}
  test:property {:doc "Run property tests."
                 :requires ([clojure.test :as test]
                            [acceptance.property-test]
                            [babashka.process :as process])
                 :task (let [result (test/run-tests 'acceptance.property-test)]
                         (let [property-result (process/shell {:out :inherit
                                                              :err :inherit
                                                              :continue true}
                                                              "npm" "run" "test:property:browser-core")]
                           (when (or (pos? (+ (:fail result) (:error result)))
                                     (not (zero? (:exit property-result))))
                             (System/exit 1))))}
  test:hardening {:doc "Run mutation hardening tests."
                  :requires ([clojure.test :as test]
                             [hardening.data-layer-timeline-hardening-test]
                             [hardening.event-library-editor-hardening-test]
                             [hardening.hotkey-keymap-hardening-test]
                             [hardening.live-observer-hardening-test]
                             [hardening.observability-source-foundation-hardening-test]
                             [hardening.operator-interface-hardening-test]
                             [hardening.project-skeleton-hardening-test]
                             [hardening.saved-sessions-hardening-test]
                             [hardening.schema-verification-hardening-test]
                             [hardening.session-boundaries-hardening-test]
                             [hardening.sequence-replay-hardening-test]
                             [hardening.workspace-editor-hardening-test])
                  :task (let [result (test/run-tests 'hardening.data-layer-timeline-hardening-test
                                                     'hardening.event-library-editor-hardening-test
                                                     'hardening.hotkey-keymap-hardening-test
                                                     'hardening.live-observer-hardening-test
                                                     'hardening.observability-source-foundation-hardening-test
                                                     'hardening.operator-interface-hardening-test
                                                     'hardening.project-skeleton-hardening-test
                                                     'hardening.saved-sessions-hardening-test
                                                     'hardening.schema-verification-hardening-test
                                                     'hardening.session-boundaries-hardening-test
                                                     'hardening.sequence-replay-hardening-test
                                                     'hardening.workspace-editor-hardening-test)]
                          (when (pos? (+ (:fail result) (:error result)))
                            (System/exit 1)))}
  test:mutation:timeline {:doc "Run focused timeline unit and mutation-hardening tests."
                          :requires ([clojure.test :as test]
                                     [acceptance.data-layer-timeline-steps-test]
                                     [hardening.data-layer-timeline-hardening-test])
                          :task (let [result (test/run-tests
                                             'acceptance.data-layer-timeline-steps-test
                                             'hardening.data-layer-timeline-hardening-test)]
                                  (when (pos? (+ (:fail result) (:error result)))
                                    (System/exit 1)))}
  acceptance {:doc "Run the normal APS acceptance pipeline."
              :requires ([acceptance.generator :as generator]
                         [babashka.fs :as fs]
                         [clojure.string :as str]
                         [babashka.process :as process])
              :task (let [features (->> (fs/list-dir "features")
                                         (filter (fn [file]
                                                   (and (fs/regular-file? file)
                                                        (str/ends-with? (fs/file-name file) ".feature"))))
                                         (sort-by (fn [file] (fs/file-name file))))
                          generated-dir "build/acceptance/generated"
                          slug (fn [path]
                                 (-> (fs/file-name (fs/strip-ext path))
                                     (str/replace (re-pattern "[^A-Za-z0-9_-]+") "-")))
                          run! (fn [& args]
                                 (let [result (apply process/shell
                                                     {:out :inherit
                                                      :err :inherit
                                                      :continue true}
                                                     args)]
                                   (when-not (zero? (:exit result))
                                     (System/exit (:exit result)))))]
                      (doseq [feature features
                              :let [name (slug feature)
                                    feature-path (str feature)
                                    ir (str "build/acceptance/ir/" name ".json")]]
                        (fs/create-dirs (fs/parent ir))
                        (run! "bb" "gherkin-parser" feature-path ir)
                        (let [{:keys [generated-file]} (generator/generate! ir generated-dir
                                                                            {:feature-path feature-path})]
                          (run! "bb" generated-file))))}
  test {:doc "Run unit, property, and acceptance tests."
        :depends [test:unit test:property acceptance]}}}
