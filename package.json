{
  "name": "my-chrome-utilities",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome utility extension skeleton.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "build": "npm run typecheck && node scripts/build.mjs",
    "package": "npm run build && node scripts/package.mjs",
    "test:unit": "bb test:unit",
    "test:unit:source-foundation": "npm run build && node test/data-layer-source-foundation-test.mjs",
    "test:unit:live-observer": "npm run build && node test/data-layer-live-observer-test.mjs",
    "test:unit:event-library-editor": "npm run build && node test/data-layer-event-library-editor-test.mjs",
    "test:unit:schema-verification": "npm run build && node test/data-layer-schema-verification-test.mjs",
    "test:unit:saved-sessions": "npm run build && node test/data-layer-saved-sessions-test.mjs",
    "test:property:browser-core": "npm run build && node test/workspace-tabs-property-test.mjs && node test/hotkey-binding-property-test.mjs && node test/data-layer-observability-property-test.mjs && node test/data-layer-schema-verification-property-test.mjs",
    "acceptance": "bb acceptance",
    "test": "bb test"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.321",
    "typescript": "^5.8.3"
  }
}
